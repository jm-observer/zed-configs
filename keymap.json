// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-d": "editor::DeleteLine",
      "ctrl-/": ["editor::ToggleComments", { "advance_downwards": false }],
      "alt-/": "editor::ToggleCodeActions",
      "alt-f": "editor::Fold",
      "alt-left": "pane::GoBack",
      "alt-right": "pane::GoForward",
      "alt-n": [
        "editor::GoToDiagnostic",
        { "severity": { "min": "error", "max": "error" } },
      ],
      "ctrl-shift-t": "project_symbols::Toggle",
      "shift shift": "file_finder::Toggle",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-shift-x": "task::Spawn",
      "alt-x": "task::Rerun",
      "ctrl-shift-m": "diagnostics::Deploy",
    },
  },
  {
    "context": "KeymapEditor",
    "unbind": {
      "alt-c": "keymap_editor::ToggleConflictFilter",
    },
  },
  {
    "context": "Pane",
    "unbind": {
      "alt-c": "search::ToggleCaseSensitive",
    },
  },
  {
    "context": "Editor && mode == full",
    "bindings": {
      "alt-c": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "Editor && mode == full",
    "unbind": {
      "ctrl-l": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "Editor && mode == full",
    "unbind": {
      "ctrl-shift-l": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "alt-c": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "Terminal",
    "unbind": {
      "ctrl-shift-.": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "Editor && mode == full",
    "unbind": {
      "ctrl-shift-.": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "AgentPanel",
    "unbind": {
      "alt-l": "agent::CycleFavoriteModels",
    },
  },
  {
    "context": "AcpThread > Editor",
    "unbind": {
      "alt-l": "agent::CycleFavoriteModels",
    },
  },
  {
    "context": "Editor && edit_prediction",
    "unbind": {
      "alt-l": "editor::AcceptEditPrediction",
    },
  },
  {
    "context": "GitCommit > Editor",
    "unbind": {
      "alt-l": "git::GenerateCommitMessage",
    },
  },
  {
    "context": "CommitEditor > Editor",
    "unbind": {
      "alt-l": "git::GenerateCommitMessage",
    },
  },
  {
    "context": "Pane",
    "unbind": {
      "alt-l": "search::ToggleSelection",
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "alt-c": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "AgentPanel",
    "unbind": {
      "ctrl-shift-.": "agent::AddSelectionToThread",
    },
  },
]
